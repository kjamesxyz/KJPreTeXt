<?xml version="1.0" encoding="utf-8"?>
<section xml:id="section-1" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>My First Section</title>
  <introduction>
    <p>Some words</p>
  </introduction>
  <subsection xml:id="subsection-1">
    <title>My First Subsection</title>
    <p>Let's try an example together.</p>
    <example>
      <p>
        What does this do? 
      </p>
    </example>

    <p> Next, let's try some math </p>
    <theorem xml:id="thm-pythag">
      <statement>
        <p>
          If <m>a,b,c</m> are the sides of a right triangle, with <m>c</m> being the hypoteneuse, then <md> a^2 + b^2 = c^2 </md>
        </p>
      </statement>
    </theorem>
    
    <figure>
      <caption>A frog</caption>
      <image source="frog.jpg" width="50%">
        <description><p>A nice-looking frog with a longish description.</p></description>
      </image>
    </figure>
    <p>Bar: <m>\foo</m></p>
  </subsection>
</section>
